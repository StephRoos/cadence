{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "boxplot-grouped",
  "description": "Distribution d'une variable numérique par modalité d'une variable catégorielle. Stats Tukey calculées côté producteur.",
  "type": "object",
  "properties": {
    "num": { "type": "string", "description": "Nom de la colonne numérique (axe X)" },
    "cat": { "type": "string", "description": "Nom de la colonne catégorielle (axe Y)" },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "modality": {},
          "count": { "type": "integer" },
          "min": { "type": "number" },
          "max": { "type": "number" },
          "q1": { "type": "number" },
          "median": { "type": "number" },
          "q3": { "type": "number" },
          "whisker_low": { "type": "number" },
          "whisker_high": { "type": "number" },
          "mean": { "type": "number" },
          "outliers": { "type": "array", "items": { "type": "number" } },
          "outliers_low_count": { "type": "integer" },
          "outliers_high_count": { "type": "integer" }
        },
        "required": ["modality", "count", "q1", "median", "q3", "whisker_low", "whisker_high"]
      }
    },
    "total_modalities": { "type": "integer" },
    "truncated": { "type": "boolean" }
  },
  "required": ["num", "cat", "groups"]
}
